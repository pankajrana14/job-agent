# ============================================================
# .env.example  –  Copy this file to ".env" and fill in values
# ============================================================
# NEVER commit ".env" to source control.

# ----------------------------------------------------------
# Gmail SMTP credentials
# ----------------------------------------------------------
# The Gmail address used to SEND the job-update emails.
GMAIL_USER=your.gmail.address@gmail.com

# Gmail App Password (16 characters, no spaces).
# Generate one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on your account.)
GMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# The address that receives the job-update emails.
# Can be the same as GMAIL_USER or a different address.
RECIPIENT_EMAIL=your.email@example.com
