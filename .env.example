# ============================================================
# .env.example  –  Copy this file to ".env" and fill in values
# ============================================================
# NEVER commit ".env" to source control.

# ----------------------------------------------------------
# Gmail SMTP credentials
# ----------------------------------------------------------
GMAIL_USER=your.gmail.address@gmail.com
GMAIL_PASSWORD=xxxx xxxx xxxx xxxx       # Gmail App Password (not your account password)
RECIPIENT_EMAIL=your.email@example.com

# ----------------------------------------------------------
# LLM evaluation (LiteLLM) — free tier default
# ----------------------------------------------------------
# Groq is free (no credit card needed): groq.com
# Free tier: 1,000 requests/day, 30 RPM — enough for a full run of ~600 jobs.
GROQ_API_KEY=gsk_...

LLM_MODEL=groq/llama-3.3-70b-versatile
LLM_FALLBACK_MODELS=groq/llama-3.1-8b-instant
LLM_PARALLEL_WORKERS=6

# Minimum LLM fit score (1–10) for a job to be included in the email.
LLM_MATCH_THRESHOLD=7

# ----------------------------------------------------------
# Paid model API keys (uncomment + add key when ready)
# ----------------------------------------------------------
# Anthropic Claude – platform.anthropic.com
#ANTHROPIC_API_KEY=sk-ant-...
#LLM_MODEL=claude-sonnet-4-6
#LLM_FALLBACK_MODELS=claude-haiku-4-5-20251001,groq/llama-3.3-70b-versatile

# OpenAI – platform.openai.com
#OPENAI_API_KEY=sk-...
#LLM_MODEL=gpt-5.5
#LLM_FALLBACK_MODELS=gpt-5.5,groq/llama-3.3-70b-versatile

# Google Gemini – aistudio.google.com
#GEMINI_API_KEY=AIza...
#LLM_MODEL=gemini/gemini-2.5-pro
#LLM_FALLBACK_MODELS=gemini/gemini-2.5-flash,groq/llama-3.3-70b-versatile

# OpenRouter (optional — use only if you need models not on Groq)
#OPENROUTER_API_KEY=sk-or-v1-...
